  },
  "embedDefaults": {
    "success": { "colour": "green", "defaultTitle": "✅ Success" },
    "error": { "colour": "red", "defaultTitle": "❌ Error" },
    "info": { "colour": "blue", "defaultTitle": "ℹ️ Info" },
    "warning": { "colour": "yellow", "defaultTitle": "⚠️ Warning" }
  },
  "logging": {
    "enabled": true,
    "level": "info",
