{
  "name": "my-discord-bot-in-typescript",
  "author": "0x474552",
  "version": "1.0.0",
  "description": "A Discord.js bot built with TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node scripts/build.mjs",
    "start": "node dist/index.js",
    "register": "tsx src/utils/deploy-commands.ts",
    "generate-config": "node scripts/generate-config-template.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.1",
    "@discordjs/ws": "^2.0.4",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "undici": "^6.26.1",
    "mysql2": "^3.11.4"
  },
  "overrides": {
    "undici": "^6.26.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}